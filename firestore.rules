rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Core user account documents
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Student gaming profiles - Read is allowed for any authenticated user (needed for Leaderboard rankings)
    match /profiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Lessons, Quizzes, Achievements & Assignments (Read-only for authenticated students)
    match /lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /achievements/{achievementId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /assignments/{assignmentId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    
    // Lesson completion tracking
    match /lessonProgress/{progressId} {
      allow read: if request.auth != null && (progressId.startsWith(request.auth.uid + '_') || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && (progressId.startsWith(request.auth.uid + '_') || request.resource.data.userId == request.auth.uid);
    }
    
    // Quiz score attempts
    match /quizAttempts/{attemptId} {
      allow read: if request.auth != null && (attemptId.startsWith(request.auth.uid + '_') || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && (attemptId.startsWith(request.auth.uid + '_') || request.resource.data.userId == request.auth.uid);
    }

    // Student unlocked achievements/badges
    match /studentAchievements/{studentAchId} {
      allow read: if request.auth != null && (studentAchId.startsWith(request.auth.uid + '_') || resource.data.userId == request.auth.uid);
      allow write: if request.auth != null && (studentAchId.startsWith(request.auth.uid + '_') || request.resource.data.userId == request.auth.uid);
    }
  }
}
